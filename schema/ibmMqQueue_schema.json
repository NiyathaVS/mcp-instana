{
    "type": "ibmMqQueue",
    "api_endpoint": "/api/infrastructure-monitoring/analyze/entities",
    "description": "Sends an application monitoring Instana API request.",
    "parameters": {
        "type": "dict",
        "description": "parameter descriptions",
        "pagination": {
            "retrievalSize": 20
        },
        "metrics": {
            "description": "The metric of ibmMqQueue.",
            "metric": [
                "queueDepth",
                "openOutputCount",
                "lastResetTime",
                "openInputCount",
                "messagesIn",
                "queueFullPercentage",
                "maxQueueDepth",
                "uncommittedMessages",
                "oldestMessage",
                "messagesOut"
            ],
            "aggregation": {
                "type": "string",
                "description": "The aggregation type of the metric.",
                "enum": [
                    "mean",
                    "sum",
                    "max",
                    "min"
                ]
            }
        },
        "tagFilterElements": {
            "description": "Generate filters for ibmMqQueue.",
            "type": "TAG_FILTER",
            "enum": [
                "type",
                "ibmmq.queuemanager.status",
                "zone",
                "host.os.version",
                "ibmmq.queuemanager.version",
                "host.os.name",
                "tag",
                "host.name",
                "host.fqdn",
                "ibmmq.queue.usage",
                "ibmmq.queue.description",
                "process.runsIn",
                "dfq.selftype",
                "tag.app2",
                "ibmmq.queue.name",
                "host.os.arch",
                "ibmmq.queuemanager.platform",
                "host.ip",
                "process.id",
                "dfq.type",
                "ibmmq.queuemanager.name",
                "host.cpu.count",
                "ibmmq.queue.type",
                "host.cpu.model",
                "metricId"
            ]
        },
        "order": {
            "description": "order by",
            "by": {
                "type": "string",
                "direction": "DESC or ASC"
            }
        },
        "groupBy": {
            "description": "group by or for each",
            "type": "enum"
        },
        "start_time": {
            "type": "string",
            "description": "If temporal information is not in the user prompt, do not generate start_time. If start_time is equal to end_time, do not generate start_time.  The start time of the time span. Format: %Y-%m-%d %H:%M:%S",
            "default": "NONE"
        },
        "end_time": {
            "type": "string",
            "description": "If temporal information is not in the user prompt, do not generate end_time. If start_time is equal to end_time, do not generate end_time. The end time of the time span. Format: %Y-%m-%d %H:%M:%S.",
            "default": "NONE"
        },
        "NLG": {
            "type": "string",
            "description": "This describes generated function call arguments. The <EOS> is used to end all sentences."
        }
    }
}